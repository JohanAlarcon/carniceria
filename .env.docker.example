# =============================================================================
# Production environment template for the Dockerized Carnicería stack.
# Copy to ".env" on the server and fill in the generated secrets.
#   cp .env.docker.example .env
# Generate values:
#   APP_KEY        -> base64:$(openssl rand -base64 32)
#   DB_PASSWORD    -> openssl rand -hex 16
#   DB_ROOT_PASSWORD -> openssl rand -hex 16
#   REVERB_APP_KEY -> openssl rand -hex 16
#   REVERB_APP_SECRET -> openssl rand -hex 16
# =============================================================================

APP_NAME="Carnicería"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://147.93.113.187:8090

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (the "db" service name is the host inside the compose network) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=carniceria
DB_USERNAME=carniceria
DB_PASSWORD=
# Used only by the mysql container to init the root account
DB_ROOT_PASSWORD=

# --- Sessions / cache / queue all live in the database ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# --- Mail (logged by default; wire real SMTP when needed) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="pedidos@carniceria.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Broadcasting / Reverb (realtime order notifications in the admin panel) ---
# REVERB_HOST/PORT are what the BROWSER and the backend publisher connect to,
# so they must be the public server address + the mapped host port (8091).
# REVERB_SERVER_* is what the reverb process binds to *inside* the container.
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=100001
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=147.93.113.187
REVERB_PORT=8091
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
